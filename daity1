    content:'';position:absolute;inset:0;
    background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(124,92,252,.12),transparent);
  }
  .cta-block::after {
    content:'';position:absolute;top:-1px;left:10%;right:10%;height:1px;
    background:linear-gradient(90deg,transparent,var(--purple2),var(--cyan),transparent);
    animation:shimmer 3s linear infinite;
