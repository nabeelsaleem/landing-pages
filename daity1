<script>
// ─── CURSOR ───
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx+'px'; cursor.style.top = my+'px';
});
(function animRing() {
  rx += (mx-rx)*0.12; ry += (my-ry)*0.12;
  ring.style.left = rx+'px'; ring.style.top = ry+'px';
  requestAnimationFrame(animRing);
})();
document.querySelectorAll('button,a,.tab-btn').forEach(el => {
  el.addEventListener('mouseenter', () => { ring.style.width='50px';ring.style.height='50px';ring.style.opacity='.5'; });
  el.addEventListener('mouseleave', () => { ring.style.width='36px';ring.style.height='36px';ring.style.opacity='1'; });
});

// ─── GRADIENT TRACKER ───
const gt = document.getElementById('gradTracker');
document.addEventListener('mousemove', e => {
  gt.style.left = e.clientX+'px'; gt.style.top = e.clientY+'px';
});

// ─── NAVBAR SCROLL ───
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  navbar.classList.toggle('scrolled', window.scrollY > 40);
});

// ─── HEATMAP ───
const hm = document.getElementById('heatmap');
const colors = ['rgba(124,92,252,.7)','rgba(59,130,246,.6)','rgba(34,211,238,.5)','rgba(245,158,11,.6)','rgba(255,255,255,.05)'];
for(let i=0;i<96;i++){
  const c = document.createElement('div');
  c.className = 'dash-cell' + (Math.random()>.65?' active':'');
  const r = Math.random();
  if(r>.85) c.style.background=colors[Math.floor(Math.random()*4)];
  else if(r>.5) c.style.background='rgba(255,255,255,.08)';
  hm.appendChild(c);
}
// Animate heatmap randomly
setInterval(()=>{
  const cells = hm.querySelectorAll('.dash-cell');
  const idx = Math.floor(Math.random()*cells.length);
  const r = Math.random();
  cells[idx].style.background = r>.7 ? colors[Math.floor(Math.random()*4)] : 'rgba(255,255,255,.06)';
  cells[idx].style.transition='background .8s';
},400);

// ─── SCROLL REVEAL ───
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting) { e.target.classList.add('visible'); }
  });
}, { threshold: 0.15 });
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el => observer.observe(el));

// ─── WORKFLOW LINE ANIMATION ───
const lineObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting){
      const lines = e.target.querySelectorAll('.workflow-line-progress');
      lines.forEach(l => { setTimeout(()=>{ l.style.width='76%'; },400); });
    }
  });
},{threshold:.3});
document.querySelectorAll('.workflow-steps').forEach(el => lineObserver.observe(el));

// ─── TABS ───
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
    const panel = document.getElementById('tab-'+this.dataset.tab);
    if(panel) panel.classList.add('active');
    // Re-trigger line animation
    setTimeout(()=>{
      panel.querySelectorAll('.workflow-line-progress').forEach(l=>{ l.style.width='0'; });
      setTimeout(()=>{ panel.querySelectorAll('.workflow-line-progress').forEach(l=>{ l.style.width='76%'; }); },100);
    },50);
  });
});

// ─── COUNT UP ───
function countUp(el, target, duration=2000) {
  const start = performance.now();
  const isDecimal = target % 1 !== 0;
  const update = (time) => {
    const elapsed = Math.min((time-start)/duration,1);
    const eased = 1-Math.pow(1-elapsed,3);
    const val = target * eased;
    el.textContent = isDecimal ? val.toFixed(1) : Math.floor(val);
    if(elapsed<1) requestAnimationFrame(update);
    else el.textContent = isDecimal ? target.toFixed(1) : target;
  };
  requestAnimationFrame(update);
}
const countObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting){
      e.target.querySelectorAll('.count').forEach(el => {
        countUp(el, parseFloat(el.dataset.target));
      });
      // Hero stats
    }
  });
},{threshold:.5});
document.querySelectorAll('.metrics-bg').forEach(el => countObserver.observe(el));

// Hero stat count (fires once on load after 1s)
setTimeout(()=>{
  countUp(document.getElementById('h1'),99.4,1800);
  countUp(document.getElementById('h2'),1.8,1800);
  countUp(document.getElementById('h3'),4.2,1800);
},900);

// ─── PARALLAX ───
window.addEventListener('scroll', () => {
  const scrolled = window.scrollY;
  document.querySelectorAll('.bg-orb').forEach((orb,i) => {
    const speed = (i+1)*0.03;
    orb.style.transform = `translateY(${scrolled*speed}px)`;
  });
});
</script>
