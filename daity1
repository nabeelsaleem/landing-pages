    background:linear-gradient(90deg,transparent,rgba(255,255,255,.4),transparent);
    transition:left .6s ease,right .6s ease;
  }
  .benefit-card:hover .shimmer-line,
  .deploy-card:hover .shimmer-line { left:0;right:0; }
</style>
</head>
